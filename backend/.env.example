# CareConnect Backend — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Required vars are validated at startup; the app should fail fast if any are missing.

# --- Runtime ---
NODE_ENV=development          # development | production
PORT=5000
FRONTEND_URL=http://localhost:5173   # used for CORS origin
BACKEND_URL=http://localhost:5000    # public base URL of this API (used in payment callbacks)

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=careconnect
DB_USER=careconnect
DB_PASSWORD=            # REQUIRED — no default; SSL should be enabled in production

# --- Firebase Admin (service account) ---
# From the Firebase service-account JSON. Keep the private key as a single line with \n escapes.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=        # e.g. "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# --- Whish Money payments ---
WHISH_API_URL=
WHISH_CHANNEL=
WHISH_SECRET=
WHISH_WEBSITE_URL=
PAYMENT_CURRENCY=USD
