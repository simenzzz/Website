# CareConnect Frontend (Vite) — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Only vars prefixed with VITE_ are exposed to the client bundle.

# Base URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# Firebase web config. NOTE: these are public client identifiers, not secrets —
# real protection comes from Firebase Auth + Storage/Firestore Security Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Maps JavaScript API key (Places library).
# Currently hardcoded in index.html — should move to this var (Vite replaces %VITE_*% in index.html).
# RESTRICT this key by HTTP referrer in Google Cloud Console — it is billable if abused.
VITE_GOOGLE_MAPS_API_KEY=
